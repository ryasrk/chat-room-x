# ── Chat Room X Environment Configuration ───────────────────────
# Cloud-only — all LLM calls go to cloud providers.
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# Control/manager API port (non-standard to avoid bot scrapers)
CONTROL_PORT=18247

# Dashboard dev server port (non-standard to avoid bot scrapers)
DASHBOARD_PORT=7391

# Dashboard origin for CORS (used by manager.js) — comma-separated for multiple origins
DASHBOARD_ORIGIN=http://YOUR_SERVER_IP:7391

# Optional: API key for control endpoints (leave empty to allow localhost-only)
CONTROL_API_KEY=

# ── Cloud Provider Configuration ────────────────────────────────
# Primary provider (EnowxAI gateway — routes to Claude, GPT, Gemini, etc.)
ENOWXAI_BASE_URL=http://YOUR_GATEWAY_IP:1430/v1
ENOWXAI_API_KEY=
ENOWXAI_MODEL=claude-opus-4.6

# Agent Room model tiers
# Brain tier: planner (high-capability reasoning/planning)
ENOWXAI_BRAIN_MODEL=gpt-5.4
# Worker tier: coder, reviewer (fast implementation)
ENOWXAI_WORKER_MODEL=gemini-2.5-flash
# Router tier: xa classification model
ENOWXAI_ROUTER_MODEL=gemini-2.5-flash

# EnowxAI gateway port (used by restart-gateway script)
ENOWXAI_GATEWAY_PORT=1431

# Redis cache for provider request coalescing/caching
REDIS_URL=redis://127.0.0.1:6379

# Frontend-visible default provider model
VITE_ENOWXAI_DEFAULT_MODEL=claude-opus-4.6

# ── Security ────────────────────────────────────────────────────
# JWT secrets (REQUIRED in production — app will exit if using defaults)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── Search Tool API Keys (optional — enables web search in chat) ──
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ── E2E Testing ────────────────────────────────────────────────
E2E_TEST_USERNAME=
E2E_TEST_PASSWORD=
# E2E_BASE_URL=http://localhost:18247
# E2E_DASHBOARD_URL=http://localhost:7391

# ── Ngrok ───────────────────────────────────────────────────────
# Ngrok tunnel for remote access (used by run_all_ngrok.sh)
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Static domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=

# ── Misc ────────────────────────────────────────────────────────
# NODE_ENV=development
# AGENT_ROOM_PYTHON_BIN=/usr/bin/python3
