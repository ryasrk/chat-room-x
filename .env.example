# ── Chat Room X Environment Configuration ───────────────────────
# Cloud-only — all LLM calls go to cloud providers.
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# Control/manager API port (non-standard to avoid bot scrapers)
CONTROL_PORT=18247

# Dashboard dev server port (non-standard to avoid bot scrapers)
DASHBOARD_PORT=7391

# Dashboard origin for CORS (used by manager.js)
DASHBOARD_ORIGIN=http://35.247.188.75:7391

# Optional: API key for control endpoints (leave empty to allow localhost-only)
CONTROL_API_KEY=

# ── Cloud Provider Configuration ────────────────────────────────
# Primary provider (EnowxAI gateway — routes to Claude, GPT, Gemini, etc.)
ENOWXAI_BASE_URL=http://172.27.160.1:1430/v1
ENOWXAI_API_KEY=
ENOWXAI_MODEL=claude-opus-4.6

# Agent Room model tiers
# Brain tier: planner (high-capability reasoning/planning)
ENOWXAI_BRAIN_MODEL=gpt-5.4
# Worker tier: coder, reviewer (fast implementation)
ENOWXAI_WORKER_MODEL=gemini-2.5-flash

# Redis cache for provider request coalescing/caching
REDIS_URL=redis://127.0.0.1:6379

# Frontend-visible default provider model
VITE_ENOWXAI_DEFAULT_MODEL=claude-opus-4.6

# Ngrok tunnel for remote access (used by run_all_ngrok.sh)
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Static domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=
